# Maintainer: Archisman Panigrahi <apandada1ATgmail.com>
# Contributor: honjow

_pkgname=vboard
pkgname="${_pkgname}-git"
pkgver=2.2.1
pkgrel=1
pkgdesc='Wayland virtual keyboard for GNU/Linux with modifier key support'
arch=('any')
url='https://github.com/archisman-panigrahi/vboard'
license=('GPL3')
install="${pkgname}.install"
depends=(
  'python'
  'python-gobject'
  'gtk3'
  'python-uinput'
  'libayatana-appindicator'
)
makedepends=(
  'git'
  'meson'
  'ninja'
)
optdepends=(
  'desktop-file-utils: provides update-desktop-database for helper scripts'
  'hunspell-en_us: enables word suggestions'
)
provides=("${_pkgname}")
conflicts=("${_pkgname}")
source=("${_pkgname}::git+https://github.com/archisman-panigrahi/vboard.git#branch=kde-fix")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/${_pkgname}"
  git describe --long --tags --abbrev=7 | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd "${srcdir}/${_pkgname}"
  meson setup build --prefix=/usr
  meson compile -C build
}

package() {
  cd "${srcdir}/${_pkgname}"
  meson install -C build --destdir "${pkgdir}"
}
