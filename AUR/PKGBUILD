# Maintainer: Archisman Panigrahi <apandada1ATgmail.com>
# Contributor: honjow

pkgname=vboard
pkgver=1.3.0
pkgrel=1
pkgdesc='Wayland compatible lightweight virtual keyboard for GNU/Linux using python-uinput'
arch=('any')
url='https://github.com/archisman-panigrahi/vboard'
license=('LGPL2.1')
install="${pkgname}.install"
depends=(
  'python'
  'python-gobject'
  'gtk3'
  'python-uinput'
  'libayatana-appindicator'
)
makedepends=(
  'meson'
  'ninja'
)
optdepends=(
  'desktop-file-utils: provides update-desktop-database for helper scripts'
)
source=("${pkgname}-${pkgver}::git+https://github.com/archisman-panigrahi/vboard.git#tag=v${pkgver}")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  meson setup build --prefix=/usr
  meson compile -C build
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  meson install -C build --destdir "${pkgdir}"
}
